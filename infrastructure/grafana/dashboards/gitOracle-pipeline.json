{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "GitOracle — AI Agent Pipeline Health Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Pipeline Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Jobs (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(gitOracle_state_transition_total{to_state=\"INGESTED\"}[24h]))",
          "legendFormat": "Jobs",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Fix Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(increase(gitOracle_state_transition_total{to_state=\"DONE\"}[24h])) / clamp_min(sum(increase(gitOracle_state_transition_total{to_state=\"INGESTED\"}[24h])), 1)",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Escalation Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(increase(gitOracle_escalation_total[24h])) / clamp_min(sum(increase(gitOracle_state_transition_total{to_state=\"INGESTED\"}[24h])), 1)",
          "legendFormat": "Escalation %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 4.5 }
            ]
          },
          "unit": "short",
          "decimals": 1
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Avg Fixer Attempts",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(gitOracle_fixer_attempts_bucket[1h])) by (le))",
          "legendFormat": "P50 attempts",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "s",
          "decimals": 0
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "LLM Latency (P95)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(gitOracle_llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📈 Job Pipeline Flow",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Job State Transitions / min",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gitOracle_state_transition_total{to_state=\"INVESTIGATING\"}[1m])) * 60", "legendFormat": "Investigating", "refId": "A" },
        { "expr": "sum(rate(gitOracle_state_transition_total{to_state=\"FIXING\"}[1m])) * 60", "legendFormat": "Fixing", "refId": "B" },
        { "expr": "sum(rate(gitOracle_state_transition_total{to_state=\"TESTING\"}[1m])) * 60", "legendFormat": "Testing", "refId": "C" },
        { "expr": "sum(rate(gitOracle_state_transition_total{to_state=\"PR_OPENED\"}[1m])) * 60", "legendFormat": "PR Opened", "refId": "D" },
        { "expr": "sum(rate(gitOracle_state_transition_total{to_state=\"DONE\"}[1m])) * 60", "legendFormat": "Done ✅", "refId": "E" },
        { "expr": "sum(rate(gitOracle_state_transition_total{to_state=\"ESCALATED\"}[1m])) * 60", "legendFormat": "Escalated ⚠️", "refId": "F" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "LLM Latency by Agent",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(gitOracle_llm_latency_seconds_bucket{agent=\"investigator\"}[5m])) by (le))", "legendFormat": "Investigator P95", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gitOracle_llm_latency_seconds_bucket{agent=\"fixer\"}[5m])) by (le))", "legendFormat": "Fixer P95", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum(rate(gitOracle_llm_latency_seconds_bucket{agent=\"reviewer\"}[5m])) by (le))", "legendFormat": "Reviewer P95", "refId": "C" },
        { "expr": "histogram_quantile(0.95, sum(rate(gitOracle_llm_latency_seconds_bucket{agent=\"planner\"}[5m])) by (le))", "legendFormat": "Planner P95", "refId": "D" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🤖 AI Quality Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Causal Confidence Score Distribution",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(gitOracle_causal_score_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.9, sum(rate(gitOracle_causal_score_bucket[5m])) by (le))", "legendFormat": "P90", "refId": "B" },
        { "expr": "histogram_quantile(0.1, sum(rate(gitOracle_causal_score_bucket[5m])) by (le))", "legendFormat": "P10", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Patch Quality Score",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(gitOracle_patch_quality_score_bucket[10m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.9, sum(rate(gitOracle_patch_quality_score_bucket[10m])) by (le))", "legendFormat": "P90", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Token Budget Utilisation",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(gitOracle_token_budget_used_total) / sum(gitOracle_token_budget_limit_total) * 100", "legendFormat": "Budget Used %", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "🔄 Feedback Loop & Learning",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "PR Outcomes (Feedback Loop)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gitOracle_feedback_outcome_total{outcome=\"PR_MERGED\"}[1h])) * 3600", "legendFormat": "Merged ✅", "refId": "A" },
        { "expr": "sum(rate(gitOracle_feedback_outcome_total{outcome=\"PR_CLOSED\"}[1h])) * 3600", "legendFormat": "Rejected ❌", "refId": "B" },
        { "expr": "sum(rate(gitOracle_feedback_outcome_total{outcome=\"COMMIT_REVERTED\"}[1h])) * 3600", "legendFormat": "Reverted ⚠️", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Agent Memory: Recalls & Stores",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gitOracle_memory_recall_total[5m])) * 60", "legendFormat": "Recalls / min", "refId": "A" },
        { "expr": "sum(rate(gitOracle_memory_store_total[5m])) * 60", "legendFormat": "Stores / min", "refId": "B" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gitOracle", "ai-agents", "pipeline"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GitOracle — Pipeline Health",
  "uid": "gitOracle-pipeline",
  "version": 1
}
