# ============================================================
# GitOracle — Environment Variables
# Copy this file to .env and fill in your values
# 
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gitOracle
POSTGRES_USER=gitOracle
POSTGRES_PASSWORD=change_me_strong_password

# ─── Neo4j ───────────────────────────────────────────────────
NEO4J_HOST=localhost
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_strong_password
NEO4J_AUTH=neo4j/change_me_strong_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=9093
# For connecting from host machine
KAFKA_EXTERNAL_HOST=localhost

# ─── Langfuse (LLM Observability) ────────────────────────────
LANGFUSE_HOST=localhost
LANGFUSE_PORT=3002
LANGFUSE_DB=langfuse
LANGFUSE_NEXTAUTH_URL=http://localhost:3002
LANGFUSE_NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
LANGFUSE_SALT=generate_with_openssl_rand_base64_32
# Get these after first Langfuse login at http://localhost:3002
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ─── Prometheus ──────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# ─── LLM Server (llama.cpp) ──────────────────────────────────
LLM_SERVER_PORT=8090
LLM_MODEL_PATH=./models/qwen2.5-coder-7b-instruct-q4_k_m.gguf
LLM_CTX_SIZE=8192
LLM_GPU_LAYERS=-1
LLM_THREADS=4

# ─── GitHub App ──────────────────────────────────────────────
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret
GITHUB_APP_CLIENT_ID=your_client_id
GITHUB_APP_CLIENT_SECRET=your_client_secret

# ─── Sentry Webhook ──────────────────────────────────────────
SENTRY_WEBHOOK_SECRET=your_sentry_webhook_secret

# ─── Spring Boot Services ─────────────────────────────────────
API_GATEWAY_PORT=8080
ERROR_INGESTOR_PORT=8081
GIT_FORENSICS_PORT=8082
ORCHESTRATOR_PORT=8083
TEST_RUNNER_PORT=8084
GITHUB_BOT_PORT=8085

# ─── Python AI Agents ─────────────────────────────────────────
INVESTIGATOR_PORT=9001
FIXER_PORT=9002
REVIEWER_PORT=9003
PLANNER_PORT=9004
PROMPT_REGISTRY_PORT=9005
GUARDRAILS_PORT=9006

# ─── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
JWT_SECRET=generate_with_openssl_rand_base64_64
JWT_EXPIRY_HOURS=24
DEFAULT_TOKEN_BUDGET=50000
CAUSAL_CONFIDENCE_THRESHOLD=0.6
MAX_FIX_ATTEMPTS=5
TEST_TIMEOUT_SECONDS=120
